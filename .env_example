# KUK2RD Development Environment Variables (Template)
# Rename this file to .env and fill in the real values

# 1. API Keys
OPENAI_API_KEY=sk-your-openai-api-key

# 2. Database Internal Credentials
POSTGRES_USER=kuk2rd_user
POSTGRES_PASSWORD=kuk2rd_password
POSTGRES_DB=kuk2rd

# 3. Connection String for App (Must match the credentials above)
DATABASE_URL=postgresql+asyncpg://kuk2rd_user:kuk2rd_password@db:5432/kuk2rd
